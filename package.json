{
  "name": "nightmare-browser",
  "version": "0.1.0",
  "description": "AI-first web browser on NW.js — zero CORS, full Node.js, API-steerable, MCP-enabled",
  "type": "module",
  "license": "MIT",
  "author": "Franz Enzenhofer",
  "repository": {
    "type": "git",
    "url": "https://github.com/franzenzenhofer/nightmare.git"
  },
  "homepage": "https://github.com/franzenzenhofer/nightmare",
  "bugs": "https://github.com/franzenzenhofer/nightmare/issues",
  "keywords": [
    "browser",
    "ai",
    "mcp",
    "nwjs",
    "automation",
    "web-scraping",
    "nodejs",
    "zero-cors",
    "headless",
    "ai-agent",
    "developer-tools"
  ],
  "scripts": {
    "predev": "node scripts/patch-nwjs.js && npm run build:browser-runtime",
    "dev": "nw src/ --devtools",
    "postinstall": "node scripts/patch-nwjs.js",
    "predev:headless": "node scripts/patch-nwjs.js && npm run build:browser-runtime",
    "dev:headless": "nw src/ --headless",
    "build:browser-runtime": "node scripts/build-browser-runtime.mjs",
    "build": "npm run build:browser-runtime && tsc",
    "prebuild:mac": "npm run build:browser-runtime",
    "build:mac": "npx nw-builder --platforms osx --arch x64,arm64 --buildDir dist/ src/",
    "prebuild:win": "npm run build:browser-runtime",
    "build:win": "npx nw-builder --platforms win --arch x64 --buildDir dist/ src/",
    "prebuild:linux": "npm run build:browser-runtime",
    "build:linux": "npx nw-builder --platforms linux --arch x64 --buildDir dist/ src/",
    "prebuild:all": "npm run build:browser-runtime",
    "build:all": "npx nw-builder --platforms osx,win,linux --arch x64 --buildDir dist/ src/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "npx vitest run --coverage",
    "test:watch": "npx vitest watch",
    "test:ui": "npx vitest --ui",
    "check": "npm run typecheck && npm run lint && npm run test",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "icons": "node scripts/generate-icons.js"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "nw-builder": "^4.17.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "nw": "^0.109.0"
  },
  "trustedDependencies": [
    "nw"
  ]
}
